# Cloudflare Pages headers
# https://developers.cloudflare.com/pages/configuration/headers/
https://usdtoworld.usdtoworld.workers.dev/
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), camera=(), microphone=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Hashed build assets: safe to cache forever
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker must always be revalidated so updates roll out promptly
/sw.js
  Cache-Control: no-cache

# Favicons / manifest: cache for a week
/favicon/*
  Cache-Control: public, max-age=604800

# HTML pages: always revalidate so content updates show immediately
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/robots.txt
  Cache-Control: public, max-age=3600

/sitemap*.xml
  Cache-Control: public, max-age=3600
