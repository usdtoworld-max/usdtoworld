---
import ErrorLayout from '../components/ErrorLayout.astro';
---
<ErrorLayout
  code="503"
  title="503 - Maintenance | UsdtoWorld"
  description="We're updating our exchange rates service. Please check back shortly."
  path="/503"
  pageName="Maintenance"
  tone="warn"
>
  <h1 data-i18n="error_503_title">We'll be right back</h1>
  <p data-i18n="error_503_message">
    We're updating our exchange rates service. Please check back shortly.
  </p>

  <div class="countdown" data-countdown aria-live="polite">
    <div class="countdown__unit"><span data-count-hours>00</span><small>hrs</small></div>
    <div class="countdown__unit"><span data-count-minutes>00</span><small>min</small></div>
    <div class="countdown__unit"><span data-count-seconds>00</span><small>sec</small></div>
  </div>
  <p class="countdown-note">Estimated time — replace with your real maintenance window.</p>

  <div class="error-actions">
    <button type="button" class="btn btn-primary" data-retry data-i18n="retry">Try again</button>
    <a href="/contact" class="btn btn-ghost" data-i18n="contact_support">Contact Support</a>
  </div>
</ErrorLayout>

<script>
  document.querySelector('[data-retry]')?.addEventListener('click', () => window.location.reload());

  function startCountdown() {
    // PLACEHOLDER target: 45 minutes from page load. Replace with a real
    // maintenance end time (e.g. rendered server-side) in production.
    const target = Date.now() + 45 * 60 * 1000;
    const hoursEl = document.querySelector('[data-count-hours]');
    const minsEl = document.querySelector('[data-count-minutes]');
    const secsEl = document.querySelector('[data-count-seconds]');
    if (!hoursEl || !minsEl || !secsEl) return;

    const pad = (n) => String(n).padStart(2, '0');

    function tick() {
      const remaining = Math.max(0, target - Date.now());
      const h = Math.floor(remaining / 3_600_000);
      const m = Math.floor((remaining % 3_600_000) / 60_000);
      const s = Math.floor((remaining % 60_000) / 1000);
      hoursEl.textContent = pad(h);
      minsEl.textContent = pad(m);
      secsEl.textContent = pad(s);
      if (remaining <= 0) clearInterval(timer);
    }
    tick();
    const timer = setInterval(tick, 1000);
  }
  startCountdown();
</script>

<style>
  .countdown { display: flex; gap: 14px; justify-content: center; margin: 30px 0 6px; }
  .countdown__unit {
    background: var(--surface-solid); border: 1px solid var(--border); border-radius: var(--radius-sm);
    padding: 14px 18px; min-width: 74px; text-align: center;
  }
  .countdown__unit span { display: block; font-family: var(--font-mono); font-size: 1.7rem; font-weight: 700; }
  .countdown__unit small { font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }
  .countdown-note { font-size: 0.78rem; color: var(--text-muted); margin-bottom: 0; }
</style>
