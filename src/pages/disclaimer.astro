---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const site = Astro.site ?? new URL('https://www.usdtoworld.com');
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.toString() },
    { '@type': 'ListItem', position: 2, name: 'Disclaimer', item: new URL('/disclaimer', site).toString() },
  ],
};
---
<Layout
  title="Disclaimer | UsdtoWorld"
  description="UsdtoWorld's exchange rate data is provided for informational purposes only. Read our full disclaimer before making financial decisions."
  path="/disclaimer"
  schema={[breadcrumbSchema]}
>
  <div class="container page-hero">
    <Breadcrumbs trail={[{ name: 'Home', href: '/' }, { name: 'Disclaimer', href: '/disclaimer' }]} />
  </div>
  <section class="section section--tight">
    <div class="container prose">
      <span class="section-eyebrow">Legal</span>
      <h1>Disclaimer</h1>
      <p class="updated-note">Last updated: July 17, 2026</p>

      <h2>Informational purposes only</h2>
      <p>
        The exchange rates, conversions, charts, and currency information displayed on UsdtoWorld are provided
        for general informational purposes only. They do not constitute financial, investment, tax, or legal
        advice, and should not be relied upon as the sole basis for any financial decision.
      </p>

      <h2>No guarantee of accuracy</h2>
      <p>
        While we aim to display accurate, up-to-date exchange rates sourced from a third-party market data
        provider, rates can change within seconds and figures shown may lag real-time market conditions. We
        make no warranty, express or implied, regarding the accuracy, completeness, or timeliness of any rate
        or conversion shown.
      </p>

      <h2>Not a financial institution</h2>
      <p>
        UsdtoWorld is not a bank, money transmitter, broker, or financial institution. We do not execute
        currency trades, hold funds, or facilitate transfers. Any actual currency exchange or transfer should
        be conducted through a licensed bank, money transfer service, or financial institution, whose quoted
        rates and fees may differ from figures shown here.
      </p>

      <h2>Third-party links</h2>
      <p>
        This site may link to third-party services or resources. We are not responsible for the content,
        accuracy, or practices of any third-party site.
      </p>

      <h2>Limitation of liability</h2>
      <p>
        To the fullest extent permitted by law, BooksnPDF shall not be liable for any
        loss or damage arising from reliance on information provided on this site, including any financial
        loss resulting from currency conversion decisions.
      </p>

      <h2>Questions</h2>
      <p>If you have questions about this disclaimer, please reach out via our <a href="/contact">Contact page</a>.</p>
    </div>
  </section>
</Layout>
