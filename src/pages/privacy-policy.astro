---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const site = Astro.site ?? new URL('https://www.usdtoworld.com');
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.toString() },
    { '@type': 'ListItem', position: 2, name: 'Privacy Policy', item: new URL('/privacy-policy', site).toString() },
  ],
};
---
<Layout
  title="Privacy Policy | UsdtoWorld"
  description="Read UsdtoWorld's privacy policy covering what data we collect, how local storage is used, and your choices."
  path="/privacy-policy"
  schema={[breadcrumbSchema]}
>
  <div class="container page-hero">
    <Breadcrumbs trail={[{ name: 'Home', href: '/' }, { name: 'Privacy Policy', href: '/privacy-policy' }]} />
  </div>
  <section class="section section--tight">
    <div class="container prose">
      <span class="section-eyebrow">Legal</span>
      <h1>Privacy Policy</h1>
      <p class="updated-note">Last updated: July 17, 2026</p>
      <p>
        This Privacy Policy explains how UsdtoWorld ("we", "us", "our") — operated by UsdtoWorld,
        located at 93 2nd Ave, New York, United States, 10003 — handles information when you use this website.
      </p>

      <h2>Information we collect</h2>
      <p>
        UsdtoWorld is designed to work without an account. We do not require you to submit personal
        information to use the converter. The following limited data may be processed:
      </p>
      <ul>
        <li><strong>Local device storage:</strong> your theme preference, language choice, and recent conversions are saved in your browser's local storage and never transmitted to our servers.</li>
        <li><strong>Newsletter sign-up:</strong> if you subscribe to rate alerts, we collect the email address you provide via our email service provider.</li>
        <li><strong>Usage analytics:</strong> we use Google Analytics to understand aggregate traffic patterns, such as which pages are visited and how long people stay. Google Analytics uses cookies and may collect your IP address; see Google's <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer">Privacy Policy</a> for details.</li>
        <li><strong>Contact form submissions:</strong> if you message us via the Contact page, we retain your message and reply-to address to respond to you.</li>
      </ul>

      <h2>How we use information</h2>
      <p>
        Any information collected is used solely to operate and improve the site, respond to inquiries, and
        send opt-in rate alerts. We do not sell personal information.
      </p>

      <h2>Third-party services</h2>
      <p>
        Live exchange rate data is retrieved from ExchangeRate-API (open.er-api.com), a third-party rate
        provider. Requests to that provider are made directly from your browser and are subject to that
        provider's own privacy practices.
      </p>

      <h2>Advertising</h2>
      <p>
        We use Google AdSense to display advertising on this site. Google and its partners may use cookies
        and similar technologies to serve ads based on your visits to this and other websites. You can opt
        out of personalized advertising by visiting Google's <a href="https://adssettings.google.com" target="_blank" rel="noopener noreferrer">Ads Settings</a>
        or <a href="https://www.aboutads.info" target="_blank" rel="noopener noreferrer">www.aboutads.info</a>.
      </p>

      <h2>Cookies and local storage</h2>
      <p>
        We use browser local storage (not tracking cookies) to remember your theme, language, and recent
        conversions — you can clear this at any time via your browser settings. Google Analytics and Google
        AdSense, described above, may separately set their own cookies to measure traffic and serve ads.
      </p>

      <h2>Your choices</h2>
      <p>
        You may unsubscribe from rate alert emails at any time using the link in any email. You may request
        deletion of any information you've submitted via our <a href="/contact">Contact page</a>.
      </p>

      <h2>Children's privacy</h2>
      <p>UsdtoWorld is not directed at children under 13, and we do not knowingly collect data from them.</p>

      <h2>Changes to this policy</h2>
      <p>We may update this policy periodically. Material changes will be reflected by updating the date above.</p>

      <h2>Contact</h2>
      <p>Questions about this policy can be sent via our <a href="/contact">Contact page</a> or to usdtoworld@gmail.com.</p>
    </div>
  </section>
</Layout>
