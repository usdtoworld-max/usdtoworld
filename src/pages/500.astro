---
import ErrorLayout from '../components/ErrorLayout.astro';
---
<ErrorLayout
  code="500"
  title="500 - Internal Server Error | UsdtoWorld"
  description="Something went wrong on our end. Please try again in a moment."
  path="/500"
  pageName="Server Error"
>
  <h1 data-i18n="error_500_title">Something went wrong</h1>
  <p data-i18n="error_500_message">
    We hit an unexpected error on our end. It's not you — try again in a moment.
  </p>

  <div class="error-actions">
    <button type="button" class="btn btn-primary" data-retry data-i18n="retry">Try again</button>
    <a href="/contact" class="btn btn-ghost" data-i18n="contact_support">Contact Support</a>
    <a href="/" class="btn btn-ghost" data-i18n="go_home">Go to Homepage</a>
  </div>
</ErrorLayout>

<script>
  document.querySelector('[data-retry]')?.addEventListener('click', () => {
    window.location.reload();
  });
</script>
