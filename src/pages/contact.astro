---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const site = Astro.site ?? new URL('https://www.usdtoworld.com');
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.toString() },
    { '@type': 'ListItem', position: 2, name: 'Contact Us', item: new URL('/contact', site).toString() },
  ],
};
---
<Layout
  title="Contact Us | UsdtoWorld"
  description="Get in touch with the UsdtoWorld team with questions, feedback, or currency pair requests."
  path="/contact"
  schema={[breadcrumbSchema]}
>
  <div class="container page-hero">
    <Breadcrumbs trail={[{ name: 'Home', href: '/' }, { name: 'Contact Us', href: '/contact' }]} />
  </div>
  <section class="section section--tight">
    <div class="container contact-grid">
      <div>
        <span class="section-eyebrow">Contact</span>
        <h1>We'd like to hear from you</h1>
        <p>
          Spotted an incorrect rate, want a currency pair added, or have general feedback? Send us a message
          and we'll get back to you.
        </p>
        <ul class="contact-meta">
          <li><strong>Email:</strong> usdtoworld@gmail.com</li>
          <li><strong>Response time:</strong> Usually within 2 business days</li>
          <li><strong>Address:</strong> 93 2nd Ave, New York, United States, 10003</li>
        </ul>
      </div>

      <form class="card contact-form" data-contact-form onsubmit="event.preventDefault(); this.reset(); this.querySelector('[data-form-msg]').hidden = false;">
        <h2 class="visually-hidden">Send us a message</h2>
        <div>
          <label for="c-name">Name</label>
          <input id="c-name" name="name" type="text" required />
        </div>
        <div>
          <label for="c-email">Email</label>
          <input id="c-email" name="email" type="email" required />
        </div>
        <div>
          <label for="c-message">Message</label>
          <textarea id="c-message" name="message" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Send message</button>
        <p data-form-msg hidden class="newsletter-msg">Thanks — we'll reply soon.</p>
      </form>
    </div>
  </section>
</Layout>

<style>
  .contact-meta { list-style: none; padding: 0; margin-top: 20px; display: flex; flex-direction: column; gap: 8px; font-size: 0.92rem; }
</style>
