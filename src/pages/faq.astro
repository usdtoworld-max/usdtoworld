---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { faqs } from '../data/faq.js';

const site = Astro.site ?? new URL('https://www.usdtoworld.com');
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.toString() },
    { '@type': 'ListItem', position: 2, name: 'FAQ', item: new URL('/faq', site).toString() },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<Layout
  title="Currency FAQ: USD, RMB, INR, EUR & More Answered | UsdtoWorld"
  description="Answers to the most common questions about USD, RMB, and other major currency pairs — exchange rate basics, transfer tips, and what moves rates."
  path="/faq"
  schema={[breadcrumbSchema, faqSchema]}
>
  <div class="container page-hero">
    <Breadcrumbs trail={[{ name: 'Home', href: '/' }, { name: 'FAQ', href: '/faq' }]} />
  </div>

  <section class="section section--tight">
    <div class="container prose">
      <span class="section-eyebrow">Help center</span>
      <h1>Currency conversion FAQ</h1>
      <p>
        Whether you're sending money abroad, checking a rate before a trip, or just curious why a currency
        moved the way it did, these are the questions people ask us most. If you don't see yours here, the
        <a href="/contact">Contact page</a> reaches a real person.
      </p>
    </div>
  </section>

  <FAQAccordion
    id="all-faq"
    eyebrow="Full list"
    heading="All questions"
    description="Every answer we currently publish, in one place."
  />

  <section class="section section--tight">
    <div class="container prose">
      <h2>Still need a number?</h2>
      <p>
        None of this replaces checking today's actual rate. Head back to the
        <a href="/#converter">live converter</a> for the current figure, or jump straight to a specific pair:
        <a href="/usd-to-inr">USD to INR</a>, <a href="/usd-to-eur">USD to EUR</a>,
        <a href="/usd-to-gbp">USD to GBP</a>, <a href="/usd-to-pkr">USD to PKR</a>, or
        <a href="/eur-to-usd">EUR to USD</a>.
      </p>
    </div>
  </section>
</Layout>
