---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  schema?: object[];
  noindex?: boolean;
}

const {
  title,
  description,
  path = '/',
  ogImage = '/og-image.png',
  schema = [],
  noindex = false,
} = Astro.props;

const site = Astro.site ?? new URL('https://www.usdtoworld.com');
const canonicalURL = new URL(path, site).toString();
const ogImageURL = new URL(ogImage, site).toString();

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'UsdtoWorld',
  url: site.toString(),
  logo: new URL('/favicon/favicon-512.png', site).toString(),
  email: 'usdtoworld@gmail.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '93 2nd Ave',
    addressLocality: 'New York',
    addressRegion: 'NY',
    postalCode: '10003',
    addressCountry: 'US',
  },
  sameAs: [],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'UsdtoWorld — USD to RMB Converter',
  url: site.toString(),
  potentialAction: {
    '@type': 'SearchAction',
    target: `${site.toString()}search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const speakableSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['h1', '.hero-sub'],
  },
  url: canonicalURL,
};

const allSchema = [organizationSchema, websiteSchema, speakableSchema, ...schema];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />

    <!-- Fonts: preconnect + direct <link> so the browser's preload scanner
         finds these immediately while parsing raw HTML, instead of only
         after downloading and parsing the bundled CSS (which is what a CSS
         @import would force). This is the single biggest lever on this
         site's LCP, since the hero heading/text use these fonts. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600;700&display=swap"
    />

    <!-- Font Awesome (brand icons in the footer only) — loaded non-blocking
         since these icons are below the fold and shouldn't affect LCP. -->
    <link
      rel="preload"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    </noscript>

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-DXMLTX9F29"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-DXMLTX9F29');
    </script>

    <!--
      Google AdSense: uncomment once approved and replace ca-pub-XXXXXXXXXXXXXXXX
      with your real publisher ID. public/ads.txt already has a matching placeholder line.
      <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXXXXXXXX" crossorigin="anonymous"></script>
    -->

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="UsdtoWorld" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Hreflang (site is served in English with client-side UI translation) -->
    <link rel="alternate" hreflang="en" href={canonicalURL} />
    <link rel="alternate" hreflang="hi" href={canonicalURL} />
    <link rel="alternate" hreflang="zh" href={canonicalURL} />
    <link rel="alternate" hreflang="es" href={canonicalURL} />
    <link rel="alternate" hreflang="ja" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />

    <meta name="theme-color" content="#3167e8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#14181f" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Usdtormb" />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />

    {allSchema.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}

    <script is:inline>
      // Apply saved theme before paint to avoid flash-of-wrong-theme.
      (function () {
        try {
          var saved = localStorage.getItem('theme');
          var theme = saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Critical for correct visible state / immediate interactivity.
      import '../scripts/theme.js';
      import '../scripts/i18n.js';

      // Non-critical: deferred to idle time so they don't compete with the
      // user's first tap/click (e.g. opening the mobile nav) for main-thread
      // time right after load — this was showing up as elevated INP on
      // #mobile-nav>a in field data.
      const deferredScripts = () => {
        import('../scripts/scroll-top.js');
        import('../scripts/register-sw.js');
        import('../scripts/recent-pages.js');
      };
      if ('requestIdleCallback' in window) {
        requestIdleCallback(deferredScripts, { timeout: 2000 });
      } else {
        setTimeout(deferredScripts, 200);
      }
    </script>
  </body>
</html>
