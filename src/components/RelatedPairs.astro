---
export interface RelatedLink { label: string; href: string; }
export interface Props { links: RelatedLink[]; }
const { links } = Astro.props as Props;
---
<section class="section section--tight related-pairs">
  <div class="container">
    <span class="section-eyebrow">Related conversions</span>
    <h2>Other pairs you might need</h2>
    <div class="related-pairs__links">
      {links.map((l) => (
        <a class="pill" href={l.href}>{l.label}</a>
      ))}
      <a class="pill" href="/#converter">All currencies →</a>
    </div>
  </div>
</section>

<style>
  .related-pairs__links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 16px; }
</style>
