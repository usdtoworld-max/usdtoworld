<div class="recent-pages-widget">
  <h2 data-i18n="recent_pages">Recently viewed pages</h2>
  <ul data-recent-pages-list>
    <li class="recent-pages-empty">You haven't visited any pages yet.</li>
  </ul>
</div>

<script>
  function renderRecentPages() {
    const list = document.querySelector('[data-recent-pages-list]');
    if (!list) return;
    let items = [];
    try {
      items = JSON.parse(localStorage.getItem('usdtoworld:recent-pages') || '[]');
    } catch (e) {}

    if (!items.length) {
      list.innerHTML = '<li class="recent-pages-empty">You haven\'t visited any pages yet.</li>';
      return;
    }
    list.innerHTML = items
      .map((i) => `<li><a href="${i.path === '' ? '/' : i.path}">${i.title || i.path}</a></li>`)
      .join('');
  }

  document.addEventListener('astro:page-load', renderRecentPages);
  renderRecentPages();
</script>

<style>
  .recent-pages-widget { text-align: left; }
  .recent-pages-widget h2 { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); font-family: var(--font-body); margin-bottom: 10px; }
  .recent-pages-widget ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 2px; }
  .recent-pages-widget li a { display: block; padding: 8px 12px; border-radius: 8px; font-size: 0.9rem; }
  .recent-pages-widget li a:hover { background: var(--bg-alt); color: var(--accent); }
  .recent-pages-empty { font-size: 0.85rem; color: var(--text-muted); padding: 8px 12px; }
</style>
