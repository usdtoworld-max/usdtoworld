---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <span class="brand__name">UsdtoWorld</span>
      <p>A free, live currency converter built for fast, accurate USD/RMB and cross-currency conversions.</p>
    </div>

    <div class="footer-col">
      <h3>Site</h3>
      <a href="/">Home</a>
      <a href="/#converter">USD to RMB</a>
      <a href="/#rates">Exchange Rates</a>
      <a href="/faq">FAQ</a>
    </div>

    <div class="footer-col">
      <h3>Legal</h3>
      <a href="/about">About Us</a>
      <a href="/privacy-policy">Privacy Policy</a>
      <a href="/disclaimer">Disclaimer</a>
      <a href="/terms">Terms &amp; Conditions</a>
      <a href="/contact">Contact Us</a>
    </div>

    <div class="footer-col footer-newsletter">
      <h3>Rate alerts</h3>
      <p>Get a monthly note when USD/RMB moves outside its usual range.</p>
      <form class="newsletter-form" onsubmit="event.preventDefault(); this.reset(); this.querySelector('[data-nl-msg]').hidden=false;">
        <label class="visually-hidden" for="newsletter-email">Email address</label>
        <input id="newsletter-email" type="email" required placeholder="you@example.com" />
        <button type="submit" class="btn btn-primary">Subscribe</button>
      </form>
      <p data-nl-msg hidden class="newsletter-msg">Thanks — check your inbox to confirm.</p>
    </div>
  </div>

  <div class="container footer-guides">
    <h3>Currency Guides</h3>
    <div class="footer-guides__links">
      <a href="/usd-to-inr">USD to INR</a>
      <a href="/usd-to-eur">USD to EUR</a>
      <a href="/usd-to-gbp">USD to GBP</a>
      <a href="/usd-to-jpy">USD to JPY</a>
      <a href="/usd-to-pkr">USD to PKR</a>
      <a href="/usd-to-cad">USD to CAD</a>
      <a href="/usd-to-aud">USD to AUD</a>
      <a href="/inr-to-usd">INR to USD</a>
      <a href="/eur-to-usd">EUR to USD</a>
      <a href="/gbp-to-usd">GBP to USD</a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p class="disclaimer-note">
      Exchange rates are provided for informational purposes only and may differ from rates offered by banks or payment providers. UsdtoWorld is not a financial institution and does not execute currency trades.
    </p>
    <div class="footer-bottom__row">
      <span>&copy; {year} UsdtoWorld. All rights reserved.</span>
    </div>

    <div class="footer-social" aria-label="Social links">
      <a
        href="https://youtube.com/@usdtoworld"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Visit our YouTube channel"
      >
        <i class="fab fa-youtube"></i>
      </a>
      <a
        href="https://facebook.com/usdtoworld"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Visit our Facebook page"
      >
        <i class="fab fa-facebook"></i>
      </a>
      <a
        href="https://instagram.com/usdtoworld"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Visit our Instagram profile"
      >
        <i class="fab fa-instagram"></i>
      </a>
      <a
        href="https://x.com/usdtoworld"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Visit our X profile"
      >
        <i class="fab fa-x-twitter"></i>
      </a>
      <a
        href="https://linkedin.com/company/usdtoworld"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Visit our LinkedIn page"
      >
        <i class="fab fa-linkedin"></i>
      </a>
    </div>
  </div>
</footer>

<button type="button" class="scroll-top" data-scroll-top aria-label="Scroll to top">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 19V5M5 12l7-7 7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
</button>

<style>
  .site-footer { background: var(--bg-alt); border-top: 1px solid var(--border); padding: 60px 0 0; }
  .footer-grid { display: grid; grid-template-columns: 1.3fr 1fr 1fr 1.3fr; gap: 32px; padding-bottom: 34px; }
  .footer-brand p { max-width: 260px; }

  .footer-col h3 { font-family: var(--font-body); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 14px; }
  .footer-col a { display: block; padding: 5px 0; color: var(--text); font-size: 0.92rem; }
  .footer-col a:hover { color: var(--accent); }

  /* Compact, full-width wrapping row for the 10 currency-pair links, kept
     visually separate from the narrow columns above so it doesn't stretch
     any single column's height. */
  .footer-guides { padding: 22px 0 30px; border-top: 1px solid var(--border); }
  .footer-guides h3 { font-family: var(--font-body); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 12px; }
  .footer-guides__links { display: flex; flex-wrap: wrap; gap: 8px 10px; }
  .footer-guides__links a {
    font-size: 0.82rem; padding: 6px 12px; border-radius: 999px; border: 1px solid var(--border);
    color: var(--text-muted); white-space: nowrap;
  }
  .footer-guides__links a:hover { color: var(--accent); border-color: var(--accent); }

  .newsletter-form { display: flex; gap: 8px; margin-top: 4px; }
  .newsletter-form input { flex: 1; min-width: 0; padding: 10px 12px; border-radius: 10px; border: 1px solid var(--border); background: var(--surface-solid); color: var(--text); }
  .newsletter-msg { color: var(--usd); font-size: 0.85rem; margin-top: 8px; }

  .footer-bottom { border-top: 1px solid var(--border); padding: 22px 0 28px; }
  .disclaimer-note { font-size: 0.8rem; max-width: 780px; }
  .footer-bottom__row { display: flex; justify-content: center; text-align: center; font-size: 0.82rem; color: var(--text-muted); margin-top: 12px; }

  /* Social icons: last element in the footer, per brand guidelines */
  .footer-social { display: flex; justify-content: center; align-items: center; gap: 14px; margin-top: 18px; }
  .footer-social a {
    width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;
    border-radius: 50%; border: 1px solid var(--border); color: var(--text-muted); font-size: 1rem;
    transition: color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .footer-social a:hover { color: var(--accent); border-color: var(--accent); transform: translateY(-1px); }

  .scroll-top {
    position: fixed; bottom: 24px; right: 24px; width: 46px; height: 46px; border-radius: 50%;
    background: var(--accent); color: var(--accent-contrast); border: none; display: flex; align-items: center;
    justify-content: center; cursor: pointer; box-shadow: 0 10px 25px -8px var(--accent);
    opacity: 0; transform: translateY(10px); pointer-events: none; transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 90;
  }
  .scroll-top.is-visible { opacity: 1; transform: translateY(0); pointer-events: auto; }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 560px) {
    .footer-grid { grid-template-columns: 1fr; }
    .footer-bottom__row { flex-direction: column; gap: 6px; }
  }
  /* Tablet / iPad range: same breathing-room fix as phones, slightly wider margin */
  @media (max-width: 1024px) {
    .footer-bottom { padding-left: 16px; padding-right: 16px; }
    .disclaimer-note { padding-left: 16px; padding-right: 16px; }
    .footer-guides { padding-left: 16px; padding-right: 16px; }
  }
  @media (max-width: 480px) {
    /* Extra breathing room so text doesn't sit flush against the screen edge */
    .footer-bottom { padding-left: 10px; padding-right: 10px; }
    .disclaimer-note { padding-left: 10px; padding-right: 10px; }
    .footer-guides { padding-left: 10px; padding-right: 10px; }
  }
</style>
